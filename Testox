    btn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then tween(btn, {BackgroundColor3=pressColor}, 0.1) end end)
    btn.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then tween(btn, {BackgroundColor3=baseColor}, 0.1) end end)
end

local function addFocusRing(box)
