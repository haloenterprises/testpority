local function renderSessions()
    for _, child in ipairs(SessionsScroll:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, session in ipairs(loadedSessions) do
        local sBtn = create("TextButton", {
            Text="", BackgroundColor3=currentSessionId==session.id and C.hover or Color3.fromRGB(20,20,26), 
            Size=UDim2.new(1, -8, 0, 32), BorderSizePixel=0, Parent=SessionsScroll
        })
        create("UICorner", {CornerRadius=UDim.new(0, 8), Parent=sBtn})
        
        local sTitle = create("TextLabel", {
            Text=session.title, Font=Enum.Font.GothamSemibold, TextSize=11, 
            TextColor3=currentSessionId==session.id and C.accent or C.text, 
            BackgroundTransparency=1, Size=UDim2.new(1, -30, 1, 0), Position=UDim2.new(0, 8, 0, 0), 
            TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd, Parent=sBtn
        })
        
        local optBtn = create("TextButton", {
            Text="⋮", Font=Enum.Font.GothamBold, TextSize=14, TextColor3=C.dim, 
            BackgroundTransparency=1, Size=UDim2.new(0, 24, 1, 0), Position=UDim2.new(1, -24, 0, 0), Parent=sBtn
        })
        
        local confirmDelete = false
        optBtn.MouseButton1Click:Connect(function()
            if confirmDelete then
                deleteSessionFromDisk(session.id)
                if currentSessionId == session.id then
                    currentSessionId = nil
                    chatHistory = {}
                    for _, c in ipairs(ChatScroll:GetChildren()) do
                        if c:IsA("CanvasGroup") then c:Destroy() end
                    end
                end
                renderSessions()
            else
                confirmDelete = true
                tween(optBtn, {TextColor3=C.red}, 0.2)
                optBtn.Text = "🗑️"
                task.delay(3, function()
                    if optBtn.Parent and confirmDelete then
                        confirmDelete = false
                        optBtn.Text = "⋮"
                        tween(optBtn, {TextColor3=C.dim}, 0.2)
                    end
                end)
            end
        end)
        
        sBtn.MouseButton1Click:Connect(function()
            if currentSessionId == session.id then return end
            currentSessionId = session.id
            chatHistory = {}
            for _, msg in ipairs(session.history) do
                table.insert(chatHistory, {role=msg.role, content=msg.content})
            end
            
            for _, c in ipairs(ChatScroll:GetChildren()) do
                if c:IsA("CanvasGroup") then c:Destroy() end
            end
            
            for _, msg in ipairs(chatHistory) do
                addMessage(msg.content, msg.role == "user", true)
            end
            renderSessions()
            
            task.defer(function() ChatScroll.CanvasPosition=Vector2.new(0,math.max(0,ChatScroll.AbsoluteCanvasSize.Y)) end)
        end)
        
        sBtn.MouseEnter:Connect(function() if currentSessionId~=session.id then tween(sBtn, {BackgroundColor3=C.hover}, 0.15) end end)
        sBtn.MouseLeave:Connect(function() if currentSessionId~=session.id then tween(sBtn, {BackgroundColor3=Color3.fromRGB(20,20,26)}, 0.15) end end)
    end
end
