    btn.MouseLeave:Connect(function() tween(btn, {BackgroundColor3=baseColor}, 0.2) end)
    btn.MouseButton1Down:Connect(function() tween(btn, {BackgroundColor3=pressColor, Size=UDim2.new(btn.Size.X.Scale, btn.Size.X.Offset-4, btn.Size.Y.Scale, btn.Size.Y.Offset-4)}, 0.1) end)
